@StarComplexAPI_HostAddress = http://127.0.0.1:5126

### تجربة تسجيل دخول موظف (مثال)
POST {{StarComplexAPI_HostAddress}}/api/Auth/employee-login
Content-Type: application/json

{
  "fullName": "اسم الموظف الثلاثي",
  "employeeCode": "EMP123"
}

